# .env.example — copy to .env and fill in values
# Used by: local camera scripts (capture_faces.py, take_attendance.py)
# Never commit .env to git!

# Get these values from Railway dashboard → your MySQL service → Variables tab
MYSQL_URL=mysql://user:password@host.railway.app:3306/railway

# Flask (only needed locally)
SECRET_KEY=generate-with-python3-c-import-secrets-print-secrets.token_hex-32

# Optional overrides (not needed if MYSQL_URL is set)
# DB_HOST=
# DB_USER=
# DB_PASSWORD=
# DB_NAME=
# DB_PORT=3306
